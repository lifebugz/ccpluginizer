{
  "name": "ccp-marketplace",
  "description": "Marketplace of pluginized non-plugin Claude Code repos",
  "owner": {
    "name": "ccpluginizer"
  },
  "plugins": [
    {
      "name": "elysiajs-skills",
      "source": {
        "source": "github",
        "repo": "elysiajs/skills"
      },
      "strict": false,
      "skills": [
        "./elysia/"
      ]
    },
    {
      "name": "jarrodwatts-claude-code-config",
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-code-config"
      },
      "strict": false,
      "skills": [
        "./skills/"
      ],
      "agents": [
        "./agents/"
      ],
      "commands": [
        "./commands/"
      ]
    },
    {
      "name": "open-circle-agent-skills",
      "source": {
        "source": "github",
        "repo": "open-circle/agent-skills"
      },
      "strict": false,
      "description": "Agent Skills for Open Circle projects including Valibot and Formisch",
      "author": {
        "name": "Open Circle"
      },
      "homepage": "https://opencircle.dev",
      "repository": "https://github.com/open-circle/agent-skills",
      "skills": [
        "./skills/valibot",
        "./skills/formisch"
      ]
    }
  ]
}
