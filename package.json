{
  "name": "ccpluginizer-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Pluginize non-plugin Claude Code resources",
  "license": "MIT",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build:marketplace": "bun scripts/build-marketplace.ts",
    "typecheck": "bun --filter '*' run typecheck",
    "lint": "bun --filter '*' run lint",
    "test": "bun test",
    "build": "bun --filter '*' run build",
    "ci:version": "changeset version",
    "prepublish:build": "bun --filter '@ccpluginizer/*' run build",
    "ci:publish": "bun run prepublish:build && for dir in packages/*; do (cd \"$dir\" && npm publish --provenance) || exit 1; done && changeset tag"
  },
  "dependencies": {
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@tsconfig/bun": "^1.0.10",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.13"
  }
}
