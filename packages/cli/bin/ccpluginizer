#!/usr/bin/env sh
# Resolve symlinks (POSIX-portable; macOS/BSD readlink lacks -f, so iterate).
script="$0"
while [ -L "$script" ]; do
  link=$(readlink "$script")
  case "$link" in
    /*) script="$link" ;;
    *)  script="$(dirname "$script")/$link" ;;
  esac
done
dist="$(cd "$(dirname "$script")" && pwd)/../dist/index.js"
# ccpluginizer is Bun-only (the dist uses Bun.* globals). Prefer bun on PATH;
# otherwise signpost both supported paths and exit non-zero — no node fallback.
if command -v bun >/dev/null 2>&1; then
  exec bun "$dist" "$@"
fi
cat >&2 <<'EOF'
ccpluginizer runs on Bun or as a standalone binary.
  • Install Bun:    curl -fsSL https://bun.sh/install | bash   then re-run
  • Or download a native binary: https://github.com/lifebugz/ccpluginizer/releases
EOF
exit 1
