{
  "name": "@ccpluginizer/ccpz",
  "version": "0.7.0",
  "description": "CLI for pluginizing non-plugin Claude Code repos",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/lifebugz/ccpluginizer#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lifebugz/ccpluginizer.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lifebugz/ccpluginizer/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "plugin",
    "marketplace",
    "cli",
    "ccpz",
    "ccpluginizer"
  ],
  "bin": {
    "ccpz": "./bin/ccpz"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "bun test",
    "build": "bun build src/index.ts --outdir dist --target bun --format esm",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@crustjs/core": "^0.0.19",
    "@crustjs/plugins": "^0.1.2",
    "@crustjs/progress": "^0.0.4",
    "@crustjs/prompts": "^0.1.0",
    "@crustjs/style": "^0.2.0",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@crustjs/crust": "^0.0.24",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.5.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
