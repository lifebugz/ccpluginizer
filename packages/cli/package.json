{
  "name": "@ccpluginizer/ccpluginizer",
  "version": "0.4.0",
  "description": "CLI for pluginizing non-plugin Claude Code repos",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/lifebugz/ccpluginizer#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lifebugz/ccpluginizer.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lifebugz/ccpluginizer/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "plugin",
    "marketplace",
    "cli",
    "ccpluginizer"
  ],
  "bin": {
    "ccpluginizer": "./bin/ccpluginizer"
  },
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "bun test",
    "build": "bun build src/index.ts --outdir dist --target node --format esm",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@crustjs/core": "^0.0.16",
    "@crustjs/plugins": "^0.0.22",
    "@crustjs/progress": "^0.0.3",
    "@crustjs/prompts": "^0.0.13",
    "@crustjs/style": "^0.1.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@crustjs/crust": "^0.0.23",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "eslint": "^10.3.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
